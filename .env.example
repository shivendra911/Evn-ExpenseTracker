# ─── Database ────────────────────────────────────────────
# Your MongoDB connection string (e.g., from MongoDB Atlas)
DATABASE_URL="mongodb+srv://<username>:<password>@cluster0.mongodb.net/expense_tracker?retryWrites=true&w=majority"

# ─── JWT Secrets ─────────────────────────────────────────
# Generate secure 64-char hex strings in terminal using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="your-generated-access-secret"
JWT_REFRESH_SECRET="your-generated-refresh-secret"

# ─── App URL ─────────────────────────────────────────────
# Set to your Vercel production domain (e.g., https://your-app.vercel.app)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Cron Secret (if using Vercel Cron Jobs) ─────────────
CRON_SECRET="your-secure-cron-secret"

# ─── Node Environment ───────────────────────────────────
NODE_ENV="production"
